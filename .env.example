# Copy this file to .env and fill in your actual keys. Do NOT commit .env to git.

# vLLM / OpenAI-compatible endpoint (required)
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://vllm.salt-lab.org/v1
OPENAI_MODEL=Qwen/Qwen3-8B

# Web Search (at least one required)
TAVILY_API_KEY=your_tavily_key_here
BRAVE_API_KEY=your_brave_key_here

# Semantic Scholar (optional - increases rate limits)
SEMANTIC_SCHOLAR_API_KEY=your_s2_key_here

# Logging
LOG_LEVEL=INFO
